{
  "env": {
    "es6": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "google"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "object-curly-spacing": ["error", "always"],
    "indent": ["error", 2],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "max-len": ["error", {"code": 120}]
  },
  "parserOptions": {
    "ecmaVersion": 2018
  }
}
